# MariTech Core Environment Config
# --------------------------------------------------

# Gemini AI Key for Wizard Bot Analysis
GEMINI_API_KEY=your_gemini_api_key_here

# NOWPayments API Integration (Bitcoin/Crypto)
# These are used for automated deposit verification and withdrawal dispatch
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret_here
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_WITHDRAWALS_ENABLED=false

# Cloudflare Pages production also needs a D1 database binding named DB.
# Apply migrations/0001_cashier_ledger.sql to that database.

# Server Settings
PORT=3000
NODE_ENV=development
