# MariTech Core Environment Config
# --------------------------------------------------

# Gemini AI Key for Wizard Bot Analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Binance Broker Integration Keys (MASTER ACCOUNT)
# These are used for automated deposit verification and withdrawal dispatch
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here
BINANCE_BASE_URL=https://api.binance.com
BINANCE_DEPOSIT_COIN=USDT
BINANCE_DEPOSIT_NETWORK=BSC
BINANCE_WITHDRAWALS_ENABLED=false

# Cloudflare Pages production also needs a D1 database binding named DB.
# Apply migrations/0001_cashier_ledger.sql to that database.

# Server Settings
PORT=3000
NODE_ENV=development
